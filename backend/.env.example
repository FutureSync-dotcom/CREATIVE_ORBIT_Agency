# ─── Vercel (Backend) Environment Variables ──────────────────────────────────
# Set these in the Vercel UI under:
#   Project → Settings → Environment Variables
#
# MongoDB Atlas connection string (SRV format recommended):
MONGODB_URI=

# Strong random secret used to sign JWT tokens:
JWT_SECRET=

# Comma-separated list of allowed frontend origins (no trailing slashes):
#   Example: https://creative-orbit.netlify.app,https://www.creativeorbit.com,https://aztechdesigns.netlify.app
CORS_ORIGIN=
